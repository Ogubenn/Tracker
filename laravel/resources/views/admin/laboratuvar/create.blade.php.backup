<script>
let parametreIndex = 1;

function parametreEkle() {
    const container = document.getElementById('parametrelerContainer');
    const yeniSatir = `
        <div class="parametre-satir border-bottom pb-3 mb-3">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label small">Parametre Adı <span class="text-danger">*</span></label>
                    <input type="text" name="parametreler[${parametreIndex}][parametre_adi]" class="form-control form-control-sm" placeholder="pH, BOİ5, KOİ..." required>
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Birim</label>
                    <input type="text" name="parametreler[${parametreIndex}][birim]" class="form-control form-control-sm" placeholder="mg/L">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Analiz Sonucu</label>
                    <input type="number" step="0.0001" name="parametreler[${parametreIndex}][analiz_sonucu]" class="form-control form-control-sm" placeholder="4.05">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Limit Değeri</label>
                    <input type="text" name="parametreler[${parametreIndex}][limit_degeri]" class="form-control form-control-sm" placeholder="25">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Analiz Metodu</label>
                    <input type="text" name="parametreler[${parametreIndex}][analiz_metodu]" class="form-control form-control-sm" placeholder="SM 5210 B">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">Tablo No</label>
                    <input type="number" name="parametreler[${parametreIndex}][tablo_no]" class="form-control form-control-sm" placeholder="1">
                </div>
                <div class="col-md-1">
                    <label class="form-label small">&nbsp;</label>
                    <button type="button" class="btn btn-danger btn-sm w-100" onclick="parametreSil(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;
    container.insertAdjacentHTML('beforeend', yeniSatir);
    parametreIndex++;
}

function parametreSil(btn) {
    btn.closest('.parametre-satir').remove();
}
</script>
@endsection
